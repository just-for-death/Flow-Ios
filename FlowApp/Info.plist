<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>Flow</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>

    <!-- Orientation -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- Background audio & video -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
        <string>fetch</string>
        <string>processing</string>
    </array>

    <key>BGTaskSchedulerPermittedIdentifiers</key>
    <array>
        <string>io.github.aedev.flow.subscription-check</string>
        <string>io.github.aedev.flow.auto-backup</string>
    </array>

    <!-- Picture in Picture -->
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <true/>

    <!-- Network -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>

    <!-- Privacy descriptions -->
    <key>NSCameraUsageDescription</key>
    <string>Flow uses the camera to scan QR codes for device-to-device sync.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Flow uses the microphone for song recognition (Shazam-style).</string>
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>Flow saves downloaded media to your photo library.</string>
    <key>NSLocalNetworkUsageDescription</key>
    <string>Flow uses your local network to discover devices for casting and device-to-device sync.</string>

    <!-- Scene -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
        <key>UISceneConfigurations</key>
        <dict/>
    </dict>

    <!-- Launch screen (blank — SwiftUI handles it) -->
    <key>UILaunchScreen</key>
    <dict/>

    <!-- Alternate app icons -->
    <key>CFBundleIcons</key>
    <dict>
        <key>CFBundlePrimaryIcon</key>
        <dict>
            <key>CFBundleIconFiles</key>
            <array>
                <string>AppIcon</string>
            </array>
            <key>UIPrebuiltIcons</key>
            <false/>
        </dict>
        <key>CFBundleAlternateIcons</key>
        <dict>
            <key>FlowRed</key>
            <dict>
                <key>CFBundleIconFiles</key>
                <array><string>FlowRed</string></array>
                <key>UIPrebuiltIcons</key>
                <false/>
            </dict>
            <key>FlowLight</key>
            <dict>
                <key>CFBundleIconFiles</key>
                <array><string>FlowLight</string></array>
                <key>UIPrebuiltIcons</key>
                <false/>
            </dict>
            <key>FlowPlay</key>
            <dict>
                <key>CFBundleIconFiles</key>
                <array><string>FlowPlay</string></array>
                <key>UIPrebuiltIcons</key>
                <false/>
            </dict>
            <key>Amoled</key>
            <dict>
                <key>CFBundleIconFiles</key>
                <array><string>Amoled</string></array>
                <key>UIPrebuiltIcons</key>
                <false/>
            </dict>
            <key>Monochrome</key>
            <dict>
                <key>CFBundleIconFiles</key>
                <array><string>Monochrome</string></array>
                <key>UIPrebuiltIcons</key>
                <false/>
            </dict>
            <key>Ghost</key>
            <dict>
                <key>CFBundleIconFiles</key>
                <array><string>Ghost</string></array>
                <key>UIPrebuiltIcons</key>
                <false/>
            </dict>
            <key>MaterialSky</key>
            <dict>
                <key>CFBundleIconFiles</key>
                <array><string>MaterialSky</string></array>
                <key>UIPrebuiltIcons</key>
                <false/>
            </dict>
            <key>MaterialMint</key>
            <dict>
                <key>CFBundleIconFiles</key>
                <array><string>MaterialMint</string></array>
                <key>UIPrebuiltIcons</key>
                <false/>
            </dict>
        </dict>
    </dict>
    <key>CFBundleIcons~ipad</key>
    <dict>
        <key>CFBundlePrimaryIcon</key>
        <dict>
            <key>CFBundleIconFiles</key>
            <array>
                <string>AppIcon</string>
            </array>
            <key>UIPrebuiltIcons</key>
            <false/>
        </dict>
        <key>CFBundleAlternateIcons</key>
        <dict>
            <key>FlowRed</key>
            <dict>
                <key>CFBundleIconFiles</key>
                <array><string>FlowRed</string></array>
                <key>UIPrebuiltIcons</key>
                <false/>
            </dict>
