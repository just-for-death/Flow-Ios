                <array><string>FlowPlay</string></array>
                <key>UIPrebuiltIcons</key>
                <false/>
            </dict>
            <key>Amoled</key>
            <dict>
                <key>CFBundleIconFiles</key>
                <array><string>Amoled</string></array>
                <key>UIPrebuiltIcons</key>
                <false/>
            </dict>
            <key>Monochrome</key>
            <dict>
                <key>CFBundleIconFiles</key>
                <array><string>Monochrome</string></array>
                <key>UIPrebuiltIcons</key>
                <false/>
            </dict>
            <key>Ghost</key>
            <dict>
                <key>CFBundleIconFiles</key>
                <array><string>Ghost</string></array>
                <key>UIPrebuiltIcons</key>
                <false/>
            </dict>
            <key>MaterialSky</key>
            <dict>
                <key>CFBundleIconFiles</key>
                <array><string>MaterialSky</string></array>
                <key>UIPrebuiltIcons</key>
                <false/>
            </dict>
            <key>MaterialMint</key>
            <dict>
                <key>CFBundleIconFiles</key>
                <array><string>MaterialMint</string></array>
                <key>UIPrebuiltIcons</key>
                <false/>
            </dict>
        </dict>
    </dict>
</dict>
</plist>
